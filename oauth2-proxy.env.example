# OAuth2 Proxy Configuration
# Copy this file to oauth2-proxy.env and fill in your values

OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_SCOPE="openid profile email"
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_COOKIE_SECURE=true
OAUTH2_PROXY_COOKIE_SAMESITE=lax
OAUTH2_PROXY_REVERSE_PROXY=true
OAUTH2_PROXY_HTTP_ADDRESS=0.0.0.0:80
# Session store: uses the bundled Valkey container
OAUTH2_PROXY_SESSION_STORE_TYPE=redis
OAUTH2_PROXY_REDIS_CONNECTION_URL=redis://valkey:6379/0

OAUTH2_PROXY_COOKIE_DOMAINS=status-admin.example.com
OAUTH2_PROXY_WHITELIST_DOMAINS=status-admin.example.com

# OIDC Provider Settings
OAUTH2_PROXY_CLIENT_ID=your-client-id
OAUTH2_PROXY_CLIENT_SECRET=your-client-secret
OAUTH2_PROXY_OIDC_ISSUER_URL=https://your-idp.example.com/
OAUTH2_PROXY_REDIRECT_URL=https://status-admin.example.com/oauth2/callback

# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
OAUTH2_PROXY_COOKIE_SECRET=generate-a-random-secret-here

OAUTH2_PROXY_UPSTREAMS=http://uptime-status-admin:80/
OAUTH2_PROXY_SKIP_AUTH_ROUTES=^/health
