# Secret key for Fernet encryption of API keys (generate with: python3 -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
SECRET_KEY=change-me-generate-a-fernet-key

# SQLite database path (inside container: /app/data/)
DATABASE_PATH=data/uptime-status.db

# Cache refresh interval in seconds
CACHE_INTERVAL=60

# Uvicorn settings
HOST=0.0.0.0
PORT=80
